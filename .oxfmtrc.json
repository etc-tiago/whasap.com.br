{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": false,
  "semi": true,
  "trailingComma": "all",
  "ignorePatterns": [
    "node_modules",
    "dist",
    ".output",
    ".wrangler",
    "**/routeTree.gen.ts",
    "bun.lock",
    "packages/db/migrations",
    "**/auto-imports.d.ts"
  ]
}