{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "oxc",
    "react",
    "import"
  ],
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    ".output",
    ".wrangler",
    "**/routeTree.gen.ts",
    "bun.lock",
    "auto-imports.d.ts",
    "routeTree.gen.ts"
  ],
  "overrides": [
    {
      "files": [
        "apps/*/src/**/*.{ts,tsx}",
        "packages/*/src/**/*.{ts,tsx}"
      ],
      "rules": {
        "react/react-in-jsx-scope": "off"
      }
    },
    {
      "files": [
        "packages/ui/**"
      ],
      "rules": {
        "react/jsx-no-constructed-context-values": "off",
        "react/no-unstable-nested-components": "off",
        "eslint/no-shadow": "off"
      }
    },
    {
      "files": [
        "packages/r2-sync/**"
      ],
      "rules": {
        "eslint/no-await-in-loop": "off"
      }
    },
    {
      "files": [
        "**/vite.config.ts"
      ],
      "rules": {
        "eslint/no-underscore-dangle": "off"
      }
    },
    {
      "files": [
        "apps/web/src/server.ts"
      ],
      "rules": {
        "import/no-unassigned-import": "off"
      }
    },
    {
      "files": [
        "apps/web/src/lib/error-reporting.ts"
      ],
      "rules": {
        "eslint/no-underscore-dangle": "off"
      }
    }
  ]
}