{
  "name": "whasap",
  "private": true,
  "packageManager": "bun@1.3.7",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check:pr": "bun run lint:fix && bun run format:fix && bun run typecheck && bun run build",
    "dev": "vp run -r --parallel --no-cache dev",
    "build": "vp run -r --cache build",
    "typecheck": "vp run -r --cache typecheck",
    "deploy": "vp run -r --no-cache deploy",
    "cf-typegen": "vp run -r --no-cache cf-typegen",
    "db:generate": "bun run --filter @whasap/db db:generate",
    "db:migrate": "bun run --filter @whasap/db db:migrate",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "validate:env": "bun scripts/validate-wrangler-vars.ts",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt ."
  },
  "devDependencies": {
    "oxfmt": "^0.16.0",
    "oxlint": "^1.16.0",
    "typescript": "^5.8.3",
    "vite-plus": "^0.2.2",
    "wrangler": "^4.54.0"
  }
}