{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "whasap-web",
  "main": "@tanstack/react-start/server-entry",
  "routes": [
    {
      "pattern": "web.whasap.com.br",
      "custom_domain": true
    }
  ],
  "compatibility_date": "2026-07-05",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "vars": {
    "WEB_URL": "http://localhost:3000",
    "OFFICE_URL": "http://localhost:3001",
    "WEBHOOK_URL": "http://localhost:8788",
    "CDN_URL": "http://localhost:8789",
    "EMAIL_FROM": "noreply@whasap.com.br"
  },
  // Secrets Store (produção): substitua store_id pelo ID real (`wrangler secrets-store store list`)
  "secrets_store_secrets": [
    {
      "binding": "ASSAS_API_KEY",
      "store_id": "76b096bc6b03460dabd7744ba277a1ee",
      "secret_name": "ASSAS_API_KEY_ETC"
    }
  ],
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "c8f9852b6dc748489154722036fb4e48",
      "localConnectionString": "postgres://postgres:postgres@db.localtest.me:5432/whasap"
    }
  ],
  "ratelimits": [
    {
      "name": "AUTH_RATE_LIMIT",
      "namespace_id": "1001",
      "simple": {
        "limit": 3,
        "period": 60
      }
    }
  ],
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "single-page-application"
  }
}