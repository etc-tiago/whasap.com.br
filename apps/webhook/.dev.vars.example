# Copie para .dev.vars (nunca commite .dev.vars):
#   cp .dev.vars.example .dev.vars
#
# Requisitos completos: docs/SECRETS-WEBHOOK.md e docs/ENV.md

# Overrides locais — sync: packages/config/src/public-urls.ts → workerVarsDevelopment
CDN_URL=http://localhost:8789

# Meta Cloud API — verify token do GET /cloud (hub.verify_token).
# Gerar: openssl rand -base64 32
WHATSAPP_CLOUD_WEBHOOK_SECRET=change-me

# Evolution — JSON { baseUrl, apiKey } (mesmo valor do apps/web). Produção: Secrets Store.
EVOLUTION_SECRETS_STORE={"baseUrl":"http://localhost:8080","apiKey":"dev-key"}
