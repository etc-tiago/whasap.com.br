# Copie para .dev.vars (nunca commite .dev.vars):
#   cp .dev.vars.example .dev.vars
#
# Requisitos completos: docs/SECRETS-WEBHOOK.md e docs/ENV.md

# Overrides locais — sync: packages/config/src/public-urls.ts → workerVarsDevelopment
CDN_URL=http://localhost:8789
EVOLUTION_BASE_URL=http://localhost:8080

# Meta Cloud API — verify token do GET /cloud (hub.verify_token).
# Gerar: openssl rand -base64 32
WHATSAPP_CLOUD_WEBHOOK_SECRET=change-me

# Asaas — authToken do webhook; header asaas-access-token no POST /asaas.
# Gerar: openssl rand -hex 32
ASAAS_WEBHOOK_TOKEN=whsec_placeholder

# Asaas API key (sandbox em dev). Produção: Secrets Store (ASSAS_API_KEY_ETC).
ASSAS_API_KEY=$aact_placeholder

# Sandbox Asaas — não definir em produção
ASAAS_SANDBOX=true

# Evolution — apikey global (mesmo valor do apps/web)
EVOLUTION_API_KEY=dev-key
